@model HealthCenterViewModel
@{
    ViewBag.Title = "HealthCareCenter";
    Layout = "_PatientLayout";
}
<style>
    #heading {
        text-align: center;
        font-size: 25px;
        background-color: #7488f2;
        font-family: serif;
        color: aliceblue;
        border-radius: 6px;
/*         margin-top: 5%;
 */    }
</style>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
<div class="row mt-3" style="text-align: end;">
@using (Html.BeginForm("AddHealthCenter", "Admin", FormMethod.Post))
{
    <div class="col-sm-1"></div>
    <div class="col-sm-10">
            <div class="card">
                <div id="heading">
                    Add Health Center
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-2">
                            <label asp-for="Name">Name</label>
                        </div>
                        <div class="col-sm-3">
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-sm-2">
                            <label asp-for="Addess">Address</label>
                        </div>
                        <div class="col-sm-3">
                            <input asp-for="Addess" class="form-control" required />
                            <span asp-validation-for="Addess" class="text-danger"></span>
                        </div>

                    </div>

                    <div class="row mt-2">

                        <div class="col-sm-2">
                            <label asp-for="City">City</label>
                        </div>
                        <div class="col-sm-3">
                            <input asp-for="City" class="form-control" required />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="col-sm-2">
                            <label asp-for="Pincode">PinCode</label>
                        </div>
                        <div class="col-sm-3">
                            <input asp-for="Pincode" class="form-control" required />
                            <span asp-validation-for="Pincode" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mt-2">
                        <div class="col-sm-4"></div>
                        <div class="col-sm-4" style="text-align:center;">
                            <button type="submit" class="btn btn-outline-success">Save</button>

                        </div>

                        <div class="col-sm-4"></div>

                    </div>

                </div>

            </div>

    </div>
    <div class="col-sm-1"></div>
}
</div>