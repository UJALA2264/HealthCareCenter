@model List<BookAppointmentMVC.Models.DoctorDetails>
@{
    ViewBag.Title = "Doctors";
    Layout = "_PatientLayout";
}

<style>
    #heading {
        text-align: center;
        font-size: 25px;
        background-color: #7488f2;
        font-family: serif;
        color: aliceblue;
        border-radius: 6px;
        margin-top: 3%;
    }
</style>

<div id="heading">Our Doctors</div>
<!-- Header -->

<!-- Search Bar -->
@using (Html.BeginForm("DoctorsList", "Common", FormMethod.Post))
{
    <div class="d-flex gap-2 m-3">
        <input class="form-control w-75" type="text" name="query" placeholder="Search" aria-label="Search" />
        <button class="btn btn-outline-success" type="submit">Search</button>
    </div>
}

<!-- No Results -->
@if (!Model.Any())
{
    <div class="alert alert-warning text-center">
        @ViewBag.Message
    </div>
}
else
{
    <!-- Doctor Cards -->
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var doc in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="@doc.ProfileName" class="card-img-top" alt="Doctor Image" style="height: 200px; object-fit: cover;" />
                    <div class="card-body p-3">
                        <h5 class="card-title mb-1">@doc.FullName</h5>
                        <p class="mb-1"><strong>Experience:</strong> @doc.ExperienceYears years</p>
                        <p class="mb-1"><strong>Qualifications:</strong> @doc.Qualifications</p>
                        <p class="mb-1"><strong>Specialization:</strong> @doc.SpecilizationName</p>
                        <p class="mb-2"><strong>Center:</strong> @doc.CenterName</p>
                        <p class="text-muted small">@doc.Summary</p>
                    </div>
                    @if (Context.Session.GetString("UserRole") == "Patient")
                    {
                        <div class="card-footer text-center">
                            <a href="@Url.Action("BookAppointment", "Patient", new { doctorId = doc.DoctorId })" class="btn btn-outline-primary btn-sm">Book Appointment</a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
